<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Rohat Kumar - Resume</title>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

    body {
      background: #f5f7fb;
      padding: 40px;
      color: #333;
    }

    .resume {
      max-width: 900px;
      margin: auto;
      background: #ffffff;
      border-radius: 20px;
      box-shadow: 0 10px 30px rgba(0,0,0,0.1);
      overflow: hidden;
    }

    .header {
      background: linear-gradient(135deg, #4f46e5, #7c3aed);
      color: white;
      padding: 30px;
      text-align: center;
    }

    .header h1 {
      font-size: 32px;
      margin-bottom: 10px;
    }

    .header p {
      font-size: 14px;
      opacity: 0.9;
    }

    .section {
      padding: 25px 30px;
      border-bottom: 1px solid #eee;
    }

    .section:last-child {
      border-bottom: none;
    }

    .section h2 {
      font-size: 18px;
      margin-bottom: 15px;
      color: #4f46e5;
      text-transform: uppercase;
      letter-spacing: 1px;
    }

    .summary {
      line-height: 1.6;
    }

    .skills {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 10px;
    }

    .skill-box {
      background: #f1f5ff;
      padding: 10px;
      border-radius: 10px;
      font-size: 14px;
    }

    .job {
      margin-bottom: 20px;
    }

    .job h3 {
      font-size: 16px;
      color: #111;
    }

    .job span {
      font-size: 13px;
      color: #777;
    }

    .job ul {
      margin-top: 10px;
      padding-left: 18px;
    }

    .job ul li {
      margin-bottom: 6px;
      font-size: 14px;
    }

    .edu, .cert {
      font-size: 14px;
      margin-bottom: 10px;
    }

    @media (max-width: 600px) {
      body {
        padding: 10px;
      }

      .header h1 {
        font-size: 24px;
      }
    }
  </style>
</head>
<body>
  <div class="resume">

    <div class="header">
